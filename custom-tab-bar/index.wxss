.custom-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  height: 88rpx;
  padding-top: 14rpx;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid rgba(8, 23, 43, 0.08);
  background: rgba(255, 255, 255, 0.98);
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  box-sizing: content-box;
}

.tab-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  color: #6f7d8c;
  font-size: 20rpx;
  line-height: 1;
}

.tab-icon {
  width: 48rpx;
  height: 48rpx;
  display: block;
}

.tab-text {
  font-size: 20rpx;
  line-height: 1;
}

.tab-item.active {
  color: #006b68;
  font-weight: 800;
}
