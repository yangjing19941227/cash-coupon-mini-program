@import "../../styles/downstream.wxss";

.assets-top {
  height: 280rpx;
  padding: 44rpx 28rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  text-align: center;
  align-items: start;
}

.asset-stat {
  min-height: 128rpx;
  border-right: 1rpx solid rgba(34, 76, 90, 0.16);
  color: #667185;
  font-size: 26rpx;
}

.asset-stat:last-child {
  border-right: 0;
}

.asset-num {
  display: inline-block;
  margin-top: 24rpx;
  color: #061426;
  font-size: 56rpx;
  line-height: 1;
  font-weight: 900;
}

.tabs4 {
  height: 76rpx;
  margin: 36rpx 0;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.78);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  text-align: center;
  color: #334153;
  font-size: 28rpx;
}

.tabs4 .active {
  color: #006b68;
  font-weight: 900;
}

.coupon-list {
  padding: 0 28rpx;
}

.coupon-row {
  display: grid;
  grid-template-columns: 120rpx 1fr 156rpx;
  gap: 28rpx;
  padding: 40rpx 0;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
}

.coupon-row:last-child {
  border-bottom: 0;
}

.coupon-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.coupon-title {
  color: #071426;
  font-size: 36rpx;
  font-weight: 900;
}

.coupon-cut {
  color: #ef4b2e;
  font-size: 32rpx;
}

.tag-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.coupon-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
}

.coupon-price {
  color: #ef4b2e;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 900;
}

.use-btn {
  min-height: 64rpx;
  padding: 0 28rpx;
  border-radius: 34rpx;
  font-size: 28rpx;
}
