@import "../../styles/downstream.wxss";

.detail-cover {
  min-height: 284rpx;
  padding: 32rpx;
  display: grid;
  grid-template-columns: 192rpx 1fr;
  gap: 28rpx;
}

.detail-cover image {
  width: 192rpx;
  height: 176rpx;
  border-radius: 16rpx;
  background: #e8f4f3;
}

.detail-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-title {
  color: #071426;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
}

.tag-row,
.price-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.price-row {
  justify-content: space-between;
}

.detail-price {
  color: #ef4b2e;
  font-size: 44rpx;
  font-weight: 900;
}

.buy-btn {
  min-height: 64rpx;
  padding: 0 34rpx;
  border-radius: 34rpx;
}

.detail-card,
.benefit-card {
  margin-top: 36rpx;
  padding: 36rpx;
}

.benefit-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.add-btn {
  width: 220rpx;
}
