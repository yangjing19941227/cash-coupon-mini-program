@import "../../styles/downstream.wxss";

.lottery-head {
  margin-top: 32rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lottery-kicker {
  color: #071426;
  font-size: 36rpx;
  font-weight: 900;
}

.lottery-box {
  margin-top: 24rpx;
  padding: 48rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.lottery-tip {
  color: #006b68;
  font-size: 40rpx;
  font-weight: 900;
}

.digits {
  margin: 24rpx 0 14rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.digit-input {
  width: 100%;
  height: 164rpx;
  box-sizing: border-box;
  border: 1rpx solid #b7d4d7;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #006b68;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
  line-height: 164rpx;
  font-weight: 900;
  text-align: center;
}

.digit-locked {
  border-color: rgba(148, 163, 184, 0.45);
  background: rgba(238, 244, 244, 0.92);
  color: #6f7d8c;
}

.random-text {
  color: #006b68;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.random-icon {
  color: #006b68;
  font-size: 34rpx;
  line-height: 1;
  font-weight: 800;
}

.random-disabled {
  color: #9aa6b2;
}

.random-disabled .random-icon {
  color: #9aa6b2;
}

.wait-state {
  margin-top: 8rpx;
  color: #6f7d8c;
  font-size: 26rpx;
}

.wait-number {
  color: #e84d33;
  font-weight: 900;
}

.submit-button {
  width: 100%;
  height: 96rpx;
  margin-top: 26rpx;
  border-radius: 16rpx;
  background: #00756f;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-button::after,
.result-button::after {
  border: 0;
}

.submit-disabled {
  background: #F4F5F9;
  color: #667185;
  opacity: 1;
}

.submit-button[disabled],
button.submit-button[disabled]:not([type]),
wx-button.submit-button[disabled][type=default] {
  background-color: #F4F5F9 !important;
  color: #667185 !important;
  opacity: 1;
}

.rule-text {
  color: #667185;
  font-size: 26rpx;
}

.note-card {
  margin-top: 40rpx;
  padding: 36rpx;
  display: grid;
  grid-template-columns: 84rpx 1fr 196rpx;
  gap: 24rpx;
  align-items: center;
}

.note-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.note-title {
  color: #071426;
  font-size: 32rpx;
  font-weight: 800;
}

.small-outline {
  min-height: 52rpx;
  padding: 0 20rpx;
  font-size: 22rpx;
  justify-self: end;
}

.result-mask {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(7, 20, 38, 0.42);
}

.result-dialog {
  width: 100%;
  box-sizing: border-box;
  padding: 44rpx 40rpx 36rpx;
  border: 1rpx solid rgba(183, 212, 215, 0.8);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-title {
  color: #071426;
  font-size: 38rpx;
  font-weight: 900;
  text-align: center;
}

.result-number-row {
  height: 72rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: rgba(239, 248, 248, 0.92);
  color: #4b5b6b;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
}

.result-number {
  color: #006b68;
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.reward-box {
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff5ef;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.reward-label {
  color: #667185;
  font-size: 26rpx;
}

.reward-value {
  color: #e84d33;
  font-size: 28rpx;
  font-weight: 900;
}

.result-muted {
  color: #667185;
  font-size: 26rpx;
  text-align: center;
}

.result-button {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  background: #00756f;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 88rpx;
}
