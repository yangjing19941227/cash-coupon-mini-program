<view class="page lottery-page">
  <view class="lottery-top-row">
    <view class="location-row">
      <text class="top-icon">位</text>
      <text>{{cityText}}</text>
    </view>
    <view class="rules-link" role="button" bindtap="goRules">
      <text class="top-icon">规</text>
      <text>开奖规则</text>
    </view>
  </view>

  <view class="lottery-heading">
    <view class="label-line"></view>
    <view class="label-dot"></view>
    <text class="lottery-label">四位数抽奖</text>
    <view class="label-dot"></view>
    <view class="label-line"></view>
  </view>

  <view class="hero-copy">
    <text class="hero-title">输入四位数参与</text>
    <text class="hero-subtitle">中奖奖励自动发放现金券</text>
  </view>

  <view class="number-card card">
    <view class="input-label-row">
      <text class="leaf-mark">⌁</text>
      <text>输入你的四位数</text>
      <text class="leaf-mark">⌁</text>
    </view>

    <view class="number-input-wrap">
      <view class="number-grid">
        <block wx:for="{{numberBoxes}}" wx:key="id">
          <view class="number-box {{item.className}}">
            <text>{{item.value}}</text>
          </view>
        </block>
      </view>

      <input
        class="manual-number-input"
        type="number"
        maxlength="4"
        value="{{currentNumber}}"
        bindinput="handleNumberInput"
        placeholder="请输入四位数字"
      />
    </view>

    <view class="random-row" role="button" bindtap="generateNumber">
      <text class="random-icon">↻</text>
      <text class="random-title">随机生成一组数字</text>
      <text class="random-tip">点击后自动填入</text>
    </view>

    <button
      class="submit-btn {{submitDisabledClass}}"
      bindtap="submitNumber"
    >
      提交参与
    </button>

    <view class="consent-row" role="button" bindtap="goRules">
      <text class="consent-icon">盾</text>
      <text>参与即同意《开奖规则》</text>
    </view>
  </view>

  <view class="info-grid">
    <block wx:for="{{infoTiles}}" wx:key="id">
      <view class="info-tile">
        <text class="info-icon">{{item.icon}}</text>
        <text class="info-label">{{item.label}}</text>
        <text class="info-value {{item.className}}">{{item.value}}</text>
      </view>
    </block>
  </view>

  <view class="records-banner card">
    <view class="records-icon">
      <text>记</text>
    </view>
    <view class="records-copy">
      <text class="records-title">参与记录 / 开奖记录 / 发券记录 可追溯</text>
      <text class="records-desc">所有记录均可在个人中心查看</text>
    </view>
    <button class="records-btn" bindtap="goRecords">查看抽奖记录</button>
  </view>
</view>
