<view class="ds-page coupon-code-page">
  <view class="ds-top">
    <view class="ds-back" bindtap="goBack">‹</view>
    <view class="ds-title">出示券码</view>
    <view class="ds-capsule" aria-hidden="true"></view>
  </view>

  <view class="ds-card coupon-brief">
    <image src="/assets/images/merchant-restaurant.png" mode="aspectFill"></image>
    <view>
      <text class="brief-title">海岛小院 · 双人海鲜套餐券</text>
      <view class="tag-row"><text class="ds-tag">海口 · 龙华区</text><text class="ds-tag">餐饮美食</text></view>
      <text class="ds-red">券后可省 ￥68</text>
    </view>
  </view>

  <view class="ds-soft-card qr-panel">
    <text class="qr-title">到店出示核销码</text>
    <text class="ds-muted">请将二维码出示给商家扫码核销</text>
    <view class="qr-code">
      <view wx:for="{{qrBlocks}}" wx:key="index" class="qr-block {{item}}"></view>
    </view>
    <view class="code-line"><text class="ds-muted">券码</text><text class="code-num">8362 0948 5170</text><text>▢</text></view>
    <text class="refresh-text">↻ 每 60 秒自动刷新</text>
    <view class="ds-card info-table">
      <view class="ds-info-line"><text>适用门店</text><text>海岛小院龙华店 ›</text></view>
      <view class="ds-info-line"><text>有效期</text><text>2026-06-30 23:59</text></view>
      <view class="ds-info-line"><text>本次可抵</text><text class="ds-red">￥68</text></view>
    </view>
    <view class="ds-btn ds-btn-block">打开亮屏模式</view>
    <view class="ds-outline-btn return-btn">返回订单</view>
  </view>
</view>
