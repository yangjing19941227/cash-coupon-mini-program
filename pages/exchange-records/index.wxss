@import "../../styles/downstream.wxss";

.record-stats {
  height: 196rpx;
  padding: 44rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  text-align: center;
}

.record-stats view {
  border-right: 1rpx solid rgba(34, 76, 90, 0.16);
  color: #071426;
  font-size: 26rpx;
}

.record-stats view:last-child {
  border-right: 0;
}

.record-num {
  display: block;
  margin: 18rpx 0 4rpx;
  color: #006b68;
  font-size: 56rpx;
  font-weight: 900;
}

.tabs4 {
  height: 76rpx;
  margin: 36rpx 0;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.78);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  text-align: center;
  color: #334153;
  font-size: 28rpx;
}

.tabs4 .active {
  color: #006b68;
  font-weight: 900;
}

.record-card {
  padding: 40rpx 32rpx;
}

.record-row {
  display: grid;
  grid-template-columns: 96rpx 1fr 168rpx;
  gap: 24rpx;
  padding: 34rpx 0;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
  align-items: center;
}

.record-row:last-child {
  border-bottom: 0;
}

.record-main,
.record-side {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-title {
  color: #071426;
  font-size: 32rpx;
  font-weight: 900;
}

.record-amount {
  color: #006b68;
  font-size: 40rpx;
  font-weight: 900;
}

.detail-btn {
  min-height: 56rpx;
  padding: 0 18rpx;
  font-size: 24rpx;
}
