<view class="ds-page lottery-records-page">
  <view class="ds-top">
    <view class="ds-back" bindtap="goBack">‹</view>
    <view class="ds-title">抽奖记录</view>
    <view class="ds-capsule" aria-hidden="true"></view>
  </view>

  <view class="ds-soft-card record-stats">
    <view><text>参与号码</text><text class="stat-num">3806</text></view>
    <view><text>中奖号码</text><text class="stat-num">9288</text></view>
    <view><text>中奖权益</text><text class="stat-num ds-red">￥30</text></view>
  </view>

  <view class="ds-card history-card">
    <text class="ds-section-title">历史记录</text>
    <view class="lottery-row">
      <view class="num-pill">3806</view>
      <view class="lottery-main"><text class="lottery-title">四位数抽奖</text><text class="ds-muted">今晚 21:38</text></view>
      <text class="ds-teal result">待开奖</text>
    </view>
    <view class="lottery-row">
      <view class="num-pill">1280</view>
      <view class="lottery-main"><text class="lottery-title">四位数抽奖</text><text class="ds-muted">昨天 21:38</text></view>
      <text class="ds-muted result">未中奖</text>
    </view>
    <view class="lottery-row">
      <view class="num-pill">6666</view>
      <view class="lottery-main"><text class="lottery-title">四位数抽奖</text><text class="ds-muted">06-15 21:38</text></view>
      <text class="ds-red result">已中奖 +￥30</text>
    </view>
  </view>

  <view class="ds-btn ds-btn-block continue-btn" bindtap="goLottery">继续参与抽奖</view>
</view>
