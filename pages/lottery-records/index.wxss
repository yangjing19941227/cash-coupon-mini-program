@import "../../styles/downstream.wxss";

.record-stats {
  height: 196rpx;
  padding: 40rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  text-align: center;
  align-items: center;
}

.record-stats view {
  border-right: 1rpx solid rgba(34, 76, 90, 0.16);
  color: #071426;
  font-size: 26rpx;
}

.record-stats view:last-child {
  border-right: 0;
}

.stat-num {
  display: block;
  margin-top: 18rpx;
  color: #006b68;
  font-size: 48rpx;
  font-weight: 900;
}

.history-card {
  margin-top: 44rpx;
  padding: 36rpx 32rpx;
}

.lottery-row {
  display: grid;
  grid-template-columns: 112rpx 1fr 150rpx;
  gap: 24rpx;
  padding: 34rpx 0;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
  align-items: center;
}

.lottery-row:last-child {
  border-bottom: 0;
}

.num-pill {
  width: 112rpx;
  height: 84rpx;
  border-radius: 16rpx;
  background: #e7f4f2;
  color: #006b68;
  font-size: 32rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lottery-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.lottery-title {
  color: #071426;
  font-size: 30rpx;
  font-weight: 900;
}

.result {
  font-size: 28rpx;
  font-weight: 900;
  text-align: right;
}

.continue-btn {
  position: fixed;
  left: 64rpx;
  right: 64rpx;
  bottom: 74rpx;
  width: auto;
}
