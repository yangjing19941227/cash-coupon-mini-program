.lottery-records-page {
  padding-bottom: 80rpx;
}

.records-nav {
  margin-bottom: 28rpx;
  min-height: 80rpx;
  display: grid;
  grid-template-columns: 88rpx minmax(0, 1fr) 88rpx;
  align-items: center;
}

.back-btn,
.nav-spacer {
  min-height: 64rpx;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  color: #006b68;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.records-nav-title {
  min-width: 0;
}

.records-summary {
  padding: 34rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  background: #fbffff;
}

.summary-title {
  color: #071827;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.2;
}

.summary-desc {
  color: #657282;
  font-size: 26rpx;
  line-height: 1.3;
}

.records-list {
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.record-card {
  min-height: 172rpx;
  padding: 30rpx;
  box-sizing: border-box;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 152rpx 144rpx;
  align-items: center;
  gap: 24rpx;
  background: #fff;
}

.record-main,
.record-number,
.record-amount,
.records-empty {
  display: flex;
  flex-direction: column;
}

.record-main {
  min-width: 0;
  gap: 14rpx;
}

.record-prize {
  color: #071827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
  overflow-wrap: anywhere;
}

.record-time {
  color: #657282;
  font-size: 24rpx;
  line-height: 1.2;
}

.record-number,
.record-amount {
  align-items: flex-end;
  gap: 12rpx;
  text-align: right;
}

.number-label,
.amount-label {
  color: #657282;
  font-size: 23rpx;
  line-height: 1.2;
}

.number-value {
  color: #006b68;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1;
}

.amount-value {
  color: #e85235;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.records-empty {
  min-height: 280rpx;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  border: 1rpx dashed #bddada;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #657282;
  font-size: 28rpx;
}

.empty-desc {
  color: #8b97a3;
  font-size: 24rpx;
}

@media (max-width: 360px) {
  .record-card {
    grid-template-columns: 1fr;
    align-items: flex-start;
  }

  .record-number,
  .record-amount {
    align-items: flex-start;
    text-align: left;
  }
}
