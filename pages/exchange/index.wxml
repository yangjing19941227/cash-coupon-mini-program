<view class="ds-page with-tab exchange-page">
  <view class="ds-top ds-top-main">
    <view class="ds-location">⌖ 海口可用⌄</view>
    <view class="ds-title">置换宝</view>
    <view class="ds-capsule" aria-hidden="true"></view>
  </view>

  <view class="ds-soft-card exchange-summary">
    <view class="summary-item">
      <text>可置换额度</text>
      <view><text class="summary-num">860</text></view>
      <text class="summary-note">1元 = 1额度，充值即得</text>
    </view>
    <view class="ds-btn recharge-btn" bindtap="goRecharge">充值额度</view>
  </view>

  <view class="exchange-hint">↻ 把闲置优惠券换成更适合你的同城权益</view>

  <view class="ds-card merchant-panel">
    <view class="ds-section-head">
      <text class="ds-section-title">置换商家</text>
      <text class="ds-muted">更多商家 ›</text>
    </view>

    <view wx:for="{{merchants}}" wx:key="id" class="merchant-row" data-id="{{item.id}}" bindtap="goExchangeSubmit">
      <image class="merchant-img" src="{{item.image}}" mode="aspectFill"></image>
      <view class="merchant-main">
        <text class="merchant-title">{{item.name}}</text>
        <view class="tag-row"><text class="ds-tag">{{item.category}}</text><text class="ds-tag">{{item.district}}</text></view>
        <view><text class="amount">{{item.exchangeAmount}}</text><text> 额度起置换</text></view>
        <text class="ds-muted">{{item.description}}</text>
      </view>
      <view class="swap-cell"><view class="swap-icon">↻</view><text>发起置换</text></view>
    </view>
  </view>
</view>
