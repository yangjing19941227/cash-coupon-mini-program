@import "../../styles/downstream.wxss";

.profile-top {
  display: grid;
  grid-template-columns: 156rpx 1fr 190rpx;
  gap: 32rpx;
  align-items: center;
}

.avatar {
  width: 156rpx;
  height: 156rpx;
  border-radius: 50%;
}

.profile-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile-name {
  color: #071426;
  font-size: 44rpx;
  font-weight: 900;
}

.profile-btn {
  min-height: 64rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.save-card {
  position: relative;
  height: 364rpx;
  margin-top: 52rpx;
  padding: 44rpx 40rpx;
  overflow: hidden;
}

.save-ill {
  position: absolute;
  right: 40rpx;
  top: 56rpx;
  width: 360rpx;
  height: 160rpx;
  opacity: 0.86;
}

.save-money {
  display: block;
  margin-top: 24rpx;
  color: #ef4b2e;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 900;
}

.profile-stats {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 36rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

.profile-stats view {
  border-right: 1rpx solid rgba(34, 76, 90, 0.14);
  color: #667185;
  font-size: 24rpx;
}

.profile-stats view:last-child {
  border-right: 0;
}

.stat-value {
  display: block;
  margin-top: 16rpx;
  color: #063f42;
  font-size: 48rpx;
  font-weight: 900;
}

.activity-card {
  margin-top: 36rpx;
  padding: 32rpx;
}

.activity-row {
  display: grid;
  grid-template-columns: 88rpx 1fr auto;
  gap: 24rpx;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
}

.activity-row:last-child {
  border-bottom: 0;
}

.activity-row view:nth-child(2) {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-title {
  color: #071426;
  font-size: 32rpx;
  font-weight: 900;
}

.row-amount {
  font-size: 30rpx;
  font-weight: 900;
}

.menu-card {
  margin-top: 36rpx;
  padding: 12rpx 32rpx;
}

.menu-line {
  height: 96rpx;
  display: grid;
  grid-template-columns: 56rpx 1fr auto 28rpx;
  gap: 20rpx;
  align-items: center;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
  color: #071426;
  font-size: 32rpx;
}

.menu-line:last-child {
  border-bottom: 0;
}

.menu-icon {
  color: #006b68;
  font-size: 40rpx;
}
