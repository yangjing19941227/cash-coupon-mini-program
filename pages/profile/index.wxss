@import "../../styles/downstream.wxss";

.profile-top {
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr) 164rpx;
  gap: 20rpx;
  align-items: center;
  min-height: 150rpx;
}

.avatar-frame {
  position: relative;
  box-sizing: border-box;
  width: 132rpx;
  height: 132rpx;
  min-width: 132rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #eaf7f4;
}

.avatar-button {
  position: absolute;
  inset: 0;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: block;
  box-sizing: border-box;
  width: 100% !important;
  height: 100% !important;
  min-width: 0;
  min-height: 0;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: transparent;
  line-height: 0;
  opacity: 0;
  overflow: hidden;
}

.avatar-button::after {
  border: 0;
}

.avatar {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-form {
  justify-self: end;
  display: block;
  box-sizing: border-box;
  width: 164rpx;
  height: 58rpx;
  min-width: 0;
  padding: 0;
  margin: 0;
}

.profile-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-location {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-name,
.profile-name-input {
  width: 100%;
  display: block;
  height: 48rpx;
  min-height: 48rpx;
  padding: 0;
  border: 0;
  background: transparent;
  color: #071426;
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 900;
}

.profile-btn {
  flex: 0 0 164rpx;
  box-sizing: border-box;
  width: 164rpx !important;
  max-width: 164rpx;
  min-width: 0;
  min-height: 58rpx;
  padding: 0 14rpx;
  margin: 0;
  border: 0;
  border-radius: 32rpx;
  font-size: 24rpx;
  line-height: 58rpx;
  white-space: nowrap;
  display: block;
}

.profile-btn::after {
  border: 0;
}

.save-card {
  position: relative;
  height: 364rpx;
  margin-top: 52rpx;
  padding: 44rpx 40rpx;
  overflow: hidden;
}

.save-ill {
  position: absolute;
  right: 40rpx;
  top: 56rpx;
  width: 360rpx;
  height: 160rpx;
  opacity: 0.86;
}

.save-money {
  display: block;
  margin-top: 24rpx;
  color: #ef4b2e;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 900;
}

.profile-stats {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 36rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

.profile-stats view {
  border-right: 1rpx solid rgba(34, 76, 90, 0.14);
  color: #667185;
  font-size: 24rpx;
}

.profile-stats view:last-child {
  border-right: 0;
}

.stat-value {
  display: block;
  margin-top: 16rpx;
  color: #063f42;
  font-size: 48rpx;
  font-weight: 900;
}

.activity-card {
  margin-top: 36rpx;
  padding: 32rpx;
}

.activity-row {
  display: grid;
  grid-template-columns: 88rpx 1fr auto;
  gap: 24rpx;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
}

.activity-row:last-child {
  border-bottom: 0;
}

.activity-row view:nth-child(2) {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-title {
  color: #071426;
  font-size: 32rpx;
  font-weight: 900;
}

.row-amount {
  font-size: 30rpx;
  font-weight: 900;
}

.menu-card {
  margin-top: 36rpx;
  padding: 12rpx 32rpx;
}

.menu-line {
  height: 96rpx;
  display: grid;
  grid-template-columns: 56rpx 1fr auto 28rpx;
  gap: 20rpx;
  align-items: center;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
  color: #071426;
  font-size: 32rpx;
}

.menu-line:last-child {
  border-bottom: 0;
}

.menu-icon {
  color: #006b68;
  font-size: 40rpx;
}
