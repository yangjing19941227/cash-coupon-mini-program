@import "../../styles/downstream.wxss";

.iconfont {
  font-family: "iconfont" !important;
  font-style: normal;
  line-height: 1;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.icon-youhuiquan::before {
  content: "▱";
}

.icon-choujiang::before {
  content: "▣";
}

.icon-zhuanhuan::before {
  content: "↔";
}

.icon-hexiao::before {
  content: "▤";
}

.icon-shangjia::before {
  content: "▥";
}

.icon-arrow-right::before {
  content: "›";
}

.profile-top {
  display: grid;
  grid-template-columns: 132rpx minmax(0, 1fr) 164rpx;
  gap: 20rpx;
  align-items: center;
  min-height: 150rpx;
}

.avatar-frame {
  position: relative;
  box-sizing: border-box;
  width: 132rpx;
  height: 132rpx;
  min-width: 132rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #eaf7f4;
}

.avatar-button {
  position: absolute;
  inset: 0;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: block;
  box-sizing: border-box;
  width: 100% !important;
  height: 100% !important;
  min-width: 0;
  min-height: 0;
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 50%;
  background: transparent;
  line-height: 0;
  opacity: 0;
  overflow: hidden;
}

.avatar-button::after {
  border: 0;
}

.avatar {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.profile-form {
  justify-self: end;
  display: block;
  box-sizing: border-box;
  width: 164rpx;
  height: 58rpx;
  min-width: 0;
  padding: 0;
  margin: 0;
}

.profile-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-location {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-name,
.profile-name-input {
  width: 100%;
  display: block;
  height: 48rpx;
  min-height: 48rpx;
  padding: 0;
  border: 0;
  background: transparent;
  color: #071426;
  font-size: 36rpx;
  line-height: 48rpx;
  font-weight: 900;
}

.profile-btn {
  flex: 0 0 164rpx;
  box-sizing: border-box;
  width: 164rpx !important;
  max-width: 164rpx;
  min-width: 0;
  min-height: 58rpx;
  padding: 0 14rpx;
  margin: 0;
  border: 0;
  border-radius: 32rpx;
  font-size: 24rpx;
  line-height: 58rpx;
  white-space: nowrap;
  display: block;
}

.profile-btn::after {
  border: 0;
}

.save-card {
  position: relative;
  height: 364rpx;
  margin-top: 36rpx;
  padding: 40rpx 40rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 107, 104, 0.16);
  background:
    radial-gradient(circle at 82% 22%, rgba(182, 228, 222, 0.5) 0, rgba(182, 228, 222, 0.22) 25%, transparent 50%),
    linear-gradient(135deg, rgba(238, 249, 247, 0.98) 0%, rgba(248, 253, 252, 0.96) 52%, rgba(231, 246, 243, 0.92) 100%);
  box-shadow: 0 16rpx 42rpx rgba(7, 20, 38, 0.05);
}

.save-card::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(241, 250, 248, 0.96) 0%, rgba(241, 250, 248, 0.78) 26%, rgba(241, 250, 248, 0.12) 52%, rgba(241, 250, 248, 0.08) 100%),
    linear-gradient(180deg, rgba(241, 250, 248, 0.82) 0%, rgba(241, 250, 248, 0.08) 36%, rgba(241, 250, 248, 0.9) 78%, rgba(241, 250, 248, 0.98) 100%);
}

.save-ill {
  position: absolute;
  right: -166rpx;
  top: -8rpx;
  width: 112%;
  height: 252rpx;
  opacity: 0.84;
  mix-blend-mode: multiply;
  z-index: 0;
}

.save-card > text,
.profile-stats {
  position: relative;
  z-index: 2;
}

.save-money {
  display: block;
  margin-top: 24rpx;
  color: #ef4b2e;
  font-size: 68rpx;
  line-height: 1;
  font-weight: 900;
}

.profile-stats {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 32rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
}

.profile-stats view {
  padding: 0rpx 12rpx;
  border-right: 1rpx solid rgba(34, 76, 90, 0.14);
  color: #667185;
  font-size: 24rpx;
}

.profile-stats view:last-child {
  border-right: 0;
}

.stat-value {
  display: block;
  margin-top: 16rpx;
  color: #063f42;
  font-size: 48rpx;
  font-weight: 900;
}

.order-card {
  margin-top: 24rpx;
  padding: 32rpx;
}

.order-title {
  display: block;
  color: #071426;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
}

.order-grid {
  margin-top: 30rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  text-align: center;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  color: #20242a;
  font-size: 26rpx;
}

.order-icon {
  color: #006b68;
  font-size: 44rpx;
  font-weight: 400;
}

.activity-card {
  margin-top: 24rpx;
  padding: 32rpx;
}

.activity-row {
  display: grid;
  grid-template-columns: 88rpx 1fr auto;
  gap: 24rpx;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
}

.activity-row:last-child {
  border-bottom: 0;
}

.activity-row view:nth-child(2) {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.row-title {
  color: #071426;
  font-size: 32rpx;
  font-weight: 900;
}

.row-amount {
  font-size: 30rpx;
  font-weight: 900;
}

.menu-card {
  margin-top: 24rpx;
  padding: 12rpx 32rpx;
}

.menu-line {
  height: 96rpx;
  display: grid;
  grid-template-columns: 56rpx 1fr auto 28rpx;
  gap: 20rpx;
  align-items: center;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
  color: #071426;
  font-size: 32rpx;
}

.menu-line:last-child {
  border-bottom: 0;
}

.menu-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #006b68;
  font-size: 40rpx;
  font-weight: 400;
}

.menu-arrow {
  color: #8b95a1;
  font-size: 28rpx;
  font-weight: 400;
  grid-column: 4;
  text-align: right;
}

.menu-title {
  font-weight: 900;
}

.menu-line .ds-muted {
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.2;
  white-space: nowrap;
}
