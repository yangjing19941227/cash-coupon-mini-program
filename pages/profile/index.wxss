.profile-page {
  padding-bottom: 176rpx;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7fbfb 52%, #f4f8f8 100%);
}

.profile-topbar {
  min-height: 82rpx;
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
}

.topbar-spacer {
  width: 72rpx;
  height: 72rpx;
}

.profile-title {
  min-height: 72rpx;
  font-size: 38rpx;
  font-weight: 900;
}

.settings-btn,
.profile-data-btn {
  margin: 0;
  padding: 0;
  border: 0;
  background: #fff;
  color: #006b68;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  line-height: 1;
}

.settings-btn::after,
.profile-data-btn::after {
  border: 0;
}

.settings-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  color: #071827;
  font-size: 28rpx;
}

.profile-header {
  margin: 40rpx 8rpx 34rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 75rpx;
  flex-shrink: 0;
  border: 6rpx solid rgba(255, 255, 255, 0.88);
  background: #e7f4f3;
  box-shadow: 0 14rpx 34rpx rgba(7, 24, 39, 0.1);
}

.profile-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.nickname {
  color: #071827;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.location {
  color: #5f6d7d;
  font-size: 28rpx;
  line-height: 1.2;
}

.profile-data-btn {
  width: 170rpx;
  height: 58rpx;
  border: 2rpx solid #b9dcda;
  border-radius: 29rpx;
  flex-shrink: 0;
  font-size: 26rpx;
}

.profile-asset-card {
  overflow: hidden;
  padding: 34rpx 34rpx 30rpx;
  background: rgba(251, 255, 255, 0.98);
}

.profile-visual-row {
  min-height: 214rpx;
  display: flex;
  align-items: center;
}

.saved-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.saved-label-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.saved-label {
  color: #5f6d7d;
  font-size: 28rpx;
  line-height: 1.2;
}

.saved-info {
  width: 26rpx;
  height: 26rpx;
  border: 2rpx solid #8a9aaa;
  border-radius: 13rpx;
  color: #6d7b88;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 800;
  line-height: 1;
}

.saved-amount-row {
  margin-top: 18rpx;
  display: flex;
  align-items: baseline;
  color: #e85235;
}

.saved-currency {
  margin-right: 8rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.saved-amount {
  font-size: 82rpx;
  font-weight: 900;
  line-height: 1;
}

.saved-helper {
  margin-top: 18rpx;
  color: #657282;
  font-size: 26rpx;
  line-height: 1.3;
}

.profile-visual {
  width: 300rpx;
  height: 180rpx;
  flex-shrink: 0;
}

.stat-card {
  margin-top: 30rpx;
  padding-top: 26rpx;
  border-top: 1rpx solid #e0ecec;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.stat-item {
  min-width: 0;
  padding: 0 8rpx;
  border-right: 1rpx solid #dfe9e9;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stat-item:last-child {
  border-right: 0;
}

.stat-icon {
  color: #006b68;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-label {
  color: #657282;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.stat-value {
  color: #0b4f52;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-value-warm {
  color: #e85235;
}

.stat-unit {
  margin-left: 4rpx;
  color: #657282;
  font-size: 22rpx;
}

.section-row {
  margin: 32rpx 8rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #071827;
  font-size: 32rpx;
  font-weight: 900;
}

.section-more {
  color: #6d7b88;
  font-size: 25rpx;
}

.activity-list {
  overflow: hidden;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: 0 16rpx 40rpx rgba(9, 48, 55, 0.06);
}

.activity-card {
  min-height: 128rpx;
  padding: 28rpx 32rpx;
  border-radius: 0;
  border: 0;
  border-bottom: 1rpx solid #e4eeee;
  box-shadow: none;
  display: flex;
  align-items: center;
}

.activity-card:last-child {
  border-bottom: 0;
}

.activity-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 9rpx;
}

.activity-title {
  color: #071827;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.activity-subtitle,
.activity-time {
  color: #657282;
  font-size: 24rpx;
  line-height: 1.25;
}

.activity-side {
  width: 148rpx;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.activity-value {
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.activity-value-plus,
.activity-value-pending {
  color: #e85235;
}

.activity-value-minus {
  color: #4c5b6a;
}

.activity-status {
  color: #657282;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.menu-card {
  overflow: hidden;
  margin-top: 28rpx;
}

.menu-row {
  min-height: 112rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #e4eeee;
}

.menu-row-last {
  border-bottom: 0;
}

.menu-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 29rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.menu-icon-coupon,
.menu-icon-exchange,
.menu-icon-verify,
.menu-icon-flow {
  background: #e7f4f3;
  color: #006b68;
}

.menu-icon-lottery {
  background: #fff3d9;
  color: #a25b00;
}

.menu-copy {
  min-width: 0;
  flex: 1;
  margin-left: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.menu-text {
  color: #071827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.menu-desc {
  color: #657282;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.menu-arrow {
  margin-left: 18rpx;
  color: #8b98a5;
  font-size: 42rpx;
  line-height: 1;
}
