.profile-page {
  padding-bottom: 176rpx;
}

.profile-title {
  margin-bottom: 24rpx;
}

.profile-card {
  position: relative;
  overflow: hidden;
  padding: 34rpx 32rpx 30rpx;
  border: 1rpx solid #bfe3e1;
  border-radius: 28rpx;
  background: #e9f8f7;
  box-shadow: 0 18rpx 42rpx rgba(8, 63, 68, 0.08);
}

.profile-card::after {
  content: "";
  position: absolute;
  right: -48rpx;
  bottom: -70rpx;
  width: 260rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.62);
}

.profile-header {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  flex-shrink: 0;
  border: 6rpx solid rgba(255, 255, 255, 0.78);
  background: #fff;
}

.profile-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.nickname {
  color: #071827;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.location {
  color: #376568;
  font-size: 26rpx;
  line-height: 1.2;
}

.settings-btn,
.profile-data-btn {
  margin: 0;
  padding: 0;
  border: 0;
  background: rgba(255, 255, 255, 0.82);
  color: #006b68;
  font-weight: 800;
  line-height: 1;
}

.settings-btn::after,
.profile-data-btn::after {
  border: 0;
}

.settings-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
}

.profile-visual-row {
  position: relative;
  z-index: 1;
  min-height: 180rpx;
  margin-top: 30rpx;
  display: flex;
  align-items: center;
}

.saved-copy {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.saved-label {
  color: #426c70;
  font-size: 24rpx;
}

.saved-amount-row {
  margin-top: 10rpx;
  display: flex;
  align-items: baseline;
  color: #005f5c;
}

.saved-currency {
  margin-right: 6rpx;
  font-size: 36rpx;
  font-weight: 800;
}

.saved-amount {
  font-size: 66rpx;
  font-weight: 900;
  line-height: 1;
}

.saved-helper {
  margin-top: 12rpx;
  color: #5b777b;
  font-size: 24rpx;
  line-height: 1.25;
}

.profile-visual {
  width: 210rpx;
  height: 170rpx;
  flex-shrink: 0;
}

.profile-data-btn {
  position: relative;
  z-index: 1;
  width: 176rpx;
  height: 60rpx;
  margin-top: 16rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.stat-card {
  margin-top: 28rpx;
  padding: 26rpx 12rpx;
  display: flex;
  align-items: stretch;
}

.stat-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  border-right: 1rpx solid #e0ecec;
}

.stat-item:last-child {
  border-right: 0;
}

.stat-label {
  color: #647080;
  font-size: 23rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.stat-value {
  color: #071827;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.stat-value-warm {
  color: #e85235;
}

.stat-unit {
  margin-left: 4rpx;
  color: #647080;
  font-size: 22rpx;
}

.section-row {
  margin: 34rpx 4rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #071827;
  font-size: 32rpx;
  font-weight: 800;
}

.section-more {
  color: #6d7b88;
  font-size: 24rpx;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.activity-card {
  min-height: 132rpx;
  padding: 26rpx 28rpx;
  display: flex;
  align-items: center;
}

.activity-main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.activity-title {
  color: #071827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.2;
}

.activity-subtitle,
.activity-time {
  color: #657282;
  font-size: 23rpx;
  line-height: 1.25;
}

.activity-side {
  width: 140rpx;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.activity-value {
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
  white-space: nowrap;
}

.activity-value-plus {
  color: #006b68;
}

.activity-value-minus {
  color: #e85235;
}

.activity-value-pending {
  color: #a25b00;
}

.activity-status {
  padding: 0 12rpx;
  border-radius: 16rpx;
  background: #eef6f6;
  color: #587579;
  font-size: 21rpx;
  line-height: 32rpx;
  white-space: nowrap;
}

.menu-card {
  overflow: hidden;
  margin-top: 28rpx;
}

.menu-row {
  min-height: 104rpx;
  padding: 0 28rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #e4eeee;
}

.menu-row-last {
  border-bottom: 0;
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 30rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.menu-icon-coupon,
.menu-icon-exchange {
  background: #e7f4f3;
  color: #006b68;
}

.menu-icon-lottery {
  background: #fff3d9;
  color: #a25b00;
}

.menu-icon-verify,
.menu-icon-flow {
  background: #eef3f4;
  color: #657282;
}

.menu-text {
  min-width: 0;
  flex: 1;
  margin-left: 22rpx;
  color: #071827;
  font-size: 30rpx;
  font-weight: 700;
}

.menu-arrow {
  color: #9aa6b2;
  font-size: 42rpx;
  line-height: 1;
}
