<view class="ds-page with-tab profile-page">
  <view class="ds-top">
    <view></view>
    <view class="ds-title">我的</view>
    <view class="ds-capsule"><text>···</text><view class="ds-capsule-line"></view><view class="ds-mini-circle"></view></view>
  </view>

  <view class="profile-top">
    <view class="avatar-frame">
      <image class="avatar" src="{{profile.avatar}}" mode="aspectFill"></image>
      <button class="avatar-button" plain="true" hover-class="none" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar"></button>
    </view>
    <view class="profile-main">
      <input class="profile-name-input" name="nickname" type="nickname" value="{{profile.nickname}}" bindinput="onNicknameInput" placeholder="同步微信昵称" />
      <text class="ds-muted profile-location">⌖ {{profile.city}} · {{profile.district}}</text>
    </view>
    <form class="profile-form" bindsubmit="saveWechatProfile">
      <button class="ds-outline-btn profile-btn" form-type="submit" hover-class="none">{{syncing ? '同步中...' : '同步资料'}}</button>
    </form>
  </view>

  <view class="ds-soft-card save-card">
    <image class="save-ill" src="/assets/images/profile-illustration.png" mode="aspectFit"></image>
    <text class="ds-muted">累计已省 ⓘ</text>
    <text class="save-money">￥{{profile.savedAmount}}</text>
    <text class="ds-muted">精打细算 · 生活更值得</text>
    <view class="profile-stats">
      <view><text>优惠券</text><text class="stat-value">{{profile.couponCount}}</text></view>
      <view><text>抽奖次数</text><text class="stat-value">{{profile.lotteryLeft}}</text></view>
      <view><text>即将过期</text><text class="stat-value">{{profile.expiringCount}}</text></view>
      <view><text>置换额度</text><text class="stat-value">{{profile.exchangeAmount}}</text></view>
    </view>
  </view>

  <view class="ds-card activity-card">
    <view class="ds-section-head">
      <text class="ds-section-title">最近权益动态</text>
      <text class="ds-muted">全部动态 ›</text>
    </view>
    <view class="activity-row">
      <view class="ds-round-icon">🎁</view>
      <view><text class="row-title">抽奖获券</text><text class="ds-muted">获得 海口湾下午茶券</text></view>
      <text class="ds-red row-amount">+ ￥30</text>
    </view>
    <view class="activity-row">
      <view class="ds-round-icon">✓</view>
      <view><text class="row-title">使用优惠券抵扣</text><text class="ds-muted">海岛小院 · 双人海鲜套餐券</text></view>
      <text class="row-amount">- ￥68</text>
    </view>
    <view class="activity-row">
      <view class="ds-round-icon">↔</view>
      <view><text class="row-title">置换申请待确认</text><text class="ds-muted">申请置换 300 额度</text></view>
      <text class="ds-red row-amount">待确认</text>
    </view>
  </view>

  <view class="ds-card menu-card">
    <view class="menu-line" bindtap="goCouponAssets"><text class="menu-icon">▱</text><text class="menu-title">我的优惠券</text><text class="ds-muted">12张可用</text><text>›</text></view>
    <view class="menu-line" bindtap="goLotteryRecords"><text class="menu-icon">▣</text><text class="menu-title">抽奖记录</text><text class="ds-muted">查看我的中奖记录</text><text>›</text></view>
    <view class="menu-line" bindtap="goExchangeRecords"><text class="menu-icon">↔</text><text class="menu-title">置换记录</text><text class="ds-muted">查看置换进度与记录</text><text>›</text></view>
    <view class="menu-line"><text class="menu-icon">▤</text><text class="menu-title">核销记录</text><text class="ds-muted">查看使用与核销明细</text><text>›</text></view>
    <view class="menu-line" bindtap="goMerchantManagement"><text class="menu-icon">▥</text><text class="menu-title">商家管理</text><text class="ds-muted">核销优惠券</text><text>›</text></view>
  </view>
</view>
