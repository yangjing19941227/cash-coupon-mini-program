<view class="ds-page orders-page">
  <view class="ds-top">
    <view class="ds-back" bindtap="goBack">‹</view>
    <view class="ds-title">我的订单</view>
    <view class="ds-capsule" aria-hidden="true"></view>
  </view>

  <view class="order-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="status"
      class="order-tab {{activeStatus === item.status ? 'order-tab-active' : ''}}"
      data-status="{{item.status}}"
      bindtap="setStatus"
    >
      {{item.label}}
    </view>
  </view>

  <view class="order-list">
    <view wx:for="{{visibleOrders}}" wx:key="id" class="order-card">
      <view class="order-title-row">
        <text class="order-title">{{item.title}}</text>
        <text class="order-status order-status-{{item.statusTone}}">{{item.statusText}}</text>
      </view>

      <view class="order-content-row">
        <image class="order-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="order-info">
          <view class="order-tags">
            <text wx:for="{{item.tags}}" wx:key="*this" class="order-tag">{{item}}</text>
          </view>
          <text class="order-meta">{{item.meta}}</text>
          <text class="order-sub-meta">{{item.subMeta}}</text>
          <view class="order-bottom-row">
            <text class="order-price">{{item.price}}</text>
            <view class="order-action" data-id="{{item.id}}" bindtap="handleOrderAction">{{item.action}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
