<view class="page home-page">
  <view class="home-top-row">
    <view class="location-pill">
      <text class="location-mark">城</text>
      <text class="location-text">{{locationText}}</text>
    </view>
    <view class="profile-link" role="button" bindtap="goProfile">我的</view>
  </view>

  <view class="nav-title home-title">首页</view>

  <view class="asset-card card">
    <view class="asset-main-row">
      <view class="asset-main">
        <text class="asset-label">累计节省</text>
        <view class="asset-amount-row">
          <text class="asset-currency">¥</text>
          <text class="asset-amount">{{savedAmountText}}</text>
        </view>
      </view>
      <view class="asset-side">
        <text class="asset-side-label">现金券余额</text>
        <text class="asset-side-value">¥{{totalValueText}}</text>
      </view>
    </view>

    <view class="asset-sub-grid">
      <view class="asset-sub-item">
        <text class="asset-sub-value">{{couponCountText}}</text>
        <text class="asset-sub-label">现金券</text>
      </view>
      <view class="asset-sub-item">
        <text class="asset-sub-value">{{exchangeAmountText}}</text>
        <text class="asset-sub-label">置换额度</text>
      </view>
      <view class="asset-sub-item">
        <text class="asset-sub-value">{{lotteryLeftText}}</text>
        <text class="asset-sub-label">抽奖次数</text>
      </view>
      <view class="asset-sub-item">
        <text class="asset-sub-value asset-sub-warm">{{expiringCountText}}</text>
        <text class="asset-sub-label">即将过期</text>
      </view>
    </view>
  </view>

  <view class="section-row">
    <text class="section-title">快捷入口</text>
  </view>

  <view class="quick-grid">
    <view class="quick-action" role="button" bindtap="goCoupons">
      <view class="quick-icon quick-icon-coupon">券</view>
      <text class="quick-label">现金券</text>
    </view>
    <view class="quick-action" role="button" bindtap="goExchange">
      <view class="quick-icon quick-icon-exchange">换</view>
      <text class="quick-label">置换</text>
    </view>
    <view class="quick-action" role="button" bindtap="goLottery">
      <view class="quick-icon quick-icon-lottery">奖</view>
      <text class="quick-label">抽奖</text>
    </view>
    <view class="quick-action" role="button" bindtap="goProfile">
      <view class="quick-icon quick-icon-profile">我</view>
      <text class="quick-label">我的</text>
    </view>
  </view>

  <view class="section-row section-row-spaced">
    <text class="section-title">附近权益</text>
    <text class="section-more" role="button" bindtap="goExchange">去置换</text>
  </view>

  <view class="benefit-list">
    <block wx:if="{{benefits.length}}">
      <block wx:for="{{benefits}}" wx:key="id">
        <view class="benefit-card card" role="button" bindtap="goExchange">
          <image class="benefit-image" src="{{item.image}}" mode="aspectFill"></image>
          <view class="benefit-copy">
            <view class="benefit-title-row">
              <text class="benefit-name">{{item.name}}</text>
              <text class="benefit-amount">¥{{item.exchangeAmountText}}</text>
            </view>
            <text class="benefit-store">{{item.store}}</text>
            <view class="tag-row">
              <block wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">
                <text class="tag">{{tag}}</text>
              </block>
            </view>
          </view>
        </view>
      </block>
    </block>
    <view wx:else class="empty">附近权益持续接入中</view>
  </view>

  <view class="section-row section-row-spaced">
    <text class="section-title">最新现金券</text>
    <text class="section-more" role="button" bindtap="goCoupons">全部</text>
  </view>

  <view wx:if="{{latestCoupon}}" class="coupon-preview card" role="button" bindtap="goLatestCoupon">
    <view class="coupon-preview-main">
      <text class="coupon-preview-title">{{latestCoupon.title}}</text>
      <text class="coupon-preview-store">{{latestCoupon.store}}</text>
      <text class="coupon-preview-expiry">{{latestCoupon.expiresText}} 到期</text>
    </view>
    <view class="coupon-preview-side">
      <text class="coupon-preview-amount">¥{{latestCoupon.amountText}}</text>
      <text class="coupon-preview-threshold">{{latestCoupon.thresholdText}}</text>
    </view>
  </view>
</view>
