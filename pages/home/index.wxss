page {
  background: #f7f7f7;
}

.local-home {
  --capsule-line-top: 88rpx;
  min-height: 100vh;
  padding: 0 30rpx 150rpx;
  background: #f7f7f7;
  color: #20242a;
  box-sizing: border-box;
}

.nav-row {
  height: 148rpx;
  margin-left: -30rpx;
  margin-right: -30rpx;
  padding-top: var(--capsule-line-top);
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 38rpx;
  padding-right: 38rpx;
  box-sizing: border-box;
  background: transparent;
}

.location {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #20262d;
  font-size: 40rpx;
  font-weight: 700;
}

.location-icon {
  color: #20262d;
  font-size: 28rpx;
}

.banner-swiper {
  height: 354rpx;
  margin-top: 48rpx;
  border-radius: 22rpx;
  overflow: hidden;
  position: relative;
  background: #e8eeee;
}

.banner-image {
  width: 100%;
  height: 354rpx;
  display: block;
}

.king-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 44rpx;
  margin: 60rpx 0 64rpx;
}

.king-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #2c3036;
  font-size: 30rpx;
}

.king-icon {
  width: 88rpx;
  height: 88rpx;
  display: block;
}

.section-title {
  position: sticky;
  top: var(--capsule-line-top);
  z-index: 20;
  margin: 0 -30rpx 30rpx;
  padding: 24rpx 38rpx 22rpx;
  color: #22262d;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 900;
  background: #f7f7f7;
}

.package-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28rpx;
  padding-bottom: 28rpx;
}

.package-card {
  border-radius: 14rpx;
  overflow: hidden;
  background: #fff;
}

.package-img {
  width: 100%;
  height: 236rpx;
  display: block;
  background: #e8eeee;
}

.package-body {
  padding: 24rpx 24rpx 28rpx;
}

.package-title {
  display: block;
  margin-bottom: 28rpx;
  color: #242830;
  font-size: 34rpx;
  line-height: 1.15;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  white-space: nowrap;
}

.price {
  color: #ef4b2e;
  font-size: 36rpx;
  font-weight: 900;
}

.old-price {
  color: #b8bec7;
  font-size: 24rpx;
  text-decoration: line-through;
}

.discount {
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  background: #fff2e8;
  color: #ff7a24;
  font-size: 24rpx;
  line-height: 1;
}
