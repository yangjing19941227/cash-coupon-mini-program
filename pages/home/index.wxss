page {
  background:
    radial-gradient(ellipse 520rpx 680rpx at 0% 0%, rgba(184, 236, 225, 0.58) 0, rgba(219, 246, 241, 0.26) 64%, rgba(255, 255, 255, 0) 86%),
    linear-gradient(180deg, #f8fdfc 10%, #f7fbfa 50%, #fafafa 100%);
}

.local-home {
  --capsule-line-top: 88rpx;
  min-height: 100vh;
  padding: 0 32rpx 150rpx;
  background:
    radial-gradient(ellipse 520rpx 680rpx at 0% 0%, rgba(184, 236, 225, 0.58) 0, rgba(219, 246, 241, 0.26) 64%, rgba(255, 255, 255, 0) 86%),
    linear-gradient(180deg, #f8fdfc 10%, #f7fbfa 50%, #fafafa 100%);
  color: #071827;
  box-sizing: border-box;
}

.nav-row {
  height: 148rpx;
  margin-left: -32rpx;
  margin-right: -32rpx;
  padding-top: var(--capsule-line-top);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 32rpx;
  padding-right: 32rpx;
  box-sizing: border-box;
  background: transparent;
}

.location {
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #071426;
  font-size: 40rpx;
  font-weight: 700;
}

.location-icon {
  color: #006b68;
  font-size: 28rpx;
}

.capsule-space {
  width: 154rpx;
  height: 64rpx;
  flex: 0 0 154rpx;
}

.banner-swiper {
  height: 354rpx;
  margin-top: 48rpx;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  background: #e8f4f3;
  border: 1rpx solid rgba(0, 107, 104, 0.12);
  box-shadow: 0 16rpx 40rpx rgba(9, 48, 55, 0.06);
}

.banner-image {
  width: 100%;
  height: 354rpx;
  display: block;
}

.king-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 44rpx;
  margin: 48rpx 0 36rpx;
  padding: 32rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.82);
  box-sizing: border-box;
}

.king-item {
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #071426;
  font-size: 30rpx;
}

.king-icon {
  width: 88rpx;
  height: 88rpx;
  display: block;
}

.section-title {
  position: sticky;
  top: var(--capsule-line-top);
  z-index: 20;
  margin: 0 -32rpx 30rpx;
  padding: 24rpx 32rpx 22rpx;
  color: #071426;
  font-size: 44rpx;
  line-height: 1;
  font-weight: 900;
  background: rgba(248, 253, 252, 0.96);
}

.package-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 28rpx;
  padding-bottom: 28rpx;
}

.package-card {
  border: 1rpx solid rgba(0, 107, 104, 0.08);
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 32rpx rgba(9, 48, 55, 0.04);
}

.package-img {
  width: 100%;
  height: 236rpx;
  display: block;
  background: #e8eeee;
}

.package-body {
  padding: 24rpx 24rpx 28rpx;
}

.package-title {
  display: block;
  margin-bottom: 28rpx;
  color: #071426;
  font-size: 34rpx;
  line-height: 1.15;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.price-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  white-space: nowrap;
}

.price {
  color: #ef4b2e;
  font-size: 36rpx;
  font-weight: 900;
}

.old-price {
  color: #b8bec7;
  font-size: 24rpx;
  text-decoration: line-through;
}

.discount {
  padding: 6rpx 10rpx;
  border-radius: 10rpx;
  background: #fff2e8;
  color: #ff7a24;
  font-size: 24rpx;
  line-height: 1;
}
