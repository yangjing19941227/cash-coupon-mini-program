page {
  background: #f8fcfc;
}

.home-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 110rpx 32rpx 154rpx;
  overflow: visible;
  background:
    radial-gradient(ellipse 420rpx 380rpx at 0% 0%, rgba(180, 236, 225, 0.66) 0, rgba(219, 246, 241, 0.42) 34%, rgba(255, 255, 255, 0) 68%),
    linear-gradient(180deg, #ecfbf8 0%, #f8fcfc 31%, #ffffff 72%, #f8fbfb 100%);
}

.hero-bridge {
  position: absolute;
  top: 192rpx;
  right: -10rpx;
  width: 432rpx;
  height: 342rpx;
  opacity: 0.92;
  z-index: 0;
}

.topbar {
  position: relative;
  z-index: 2;
  height: 68rpx;
  display: grid;
  grid-template-columns: 116rpx 1fr 154rpx;
  gap: 34rpx;
  align-items: center;
}

.city {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #071226;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1;
}

.chevron {
  margin-top: -6rpx;
  font-size: 40rpx;
  font-weight: 500;
}

.search-box {
  height: 64rpx;
  padding: 0 26rpx;
  border: 2rpx solid rgba(8, 23, 43, 0.17);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.82);
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #747b86;
  font-size: 28rpx;
  white-space: nowrap;
}

.search-icon {
  font-size: 42rpx;
  line-height: 1;
  transform: rotate(-20deg);
}

.search-text {
  overflow: hidden;
  text-overflow: ellipsis;
}

.capsule-space {
  width: 154rpx;
  height: 64rpx;
}

.hero-copy {
  position: relative;
  z-index: 1;
  margin-top: 118rpx;
  display: flex;
  flex-direction: column;
}

.hero-title {
  color: #071226;
  font-size: 70rpx;
  line-height: 1.14;
  font-weight: 900;
  letter-spacing: 1rpx;
}

.hero-subtitle {
  margin-top: 30rpx;
  color: #455267;
  font-size: 32rpx;
  line-height: 1.25;
  letter-spacing: 2rpx;
}

.asset-card {
  position: relative;
  z-index: 2;
  margin-top: 104rpx;
  height: 360rpx;
  border: 2rpx solid rgba(0, 104, 103, 0.25);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.62);
  overflow: hidden;
}

.asset-head,
.deal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.asset-head {
  padding: 40rpx 32rpx 0;
}

.card-title {
  color: #071226;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 900;
}

.available-city {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #0a6565;
  font-size: 28rpx;
  font-weight: 700;
}

.small-icon {
  width: 30rpx;
  height: 30rpx;
}

.asset-stats {
  margin: 48rpx 30rpx 0;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  height: 176rpx;
}

.asset-stat {
  position: relative;
  min-width: 0;
  padding: 10rpx 22rpx 0;
}

.asset-stat:not(:last-child)::after {
  content: "";
  position: absolute;
  top: 16rpx;
  right: 0;
  width: 2rpx;
  height: 146rpx;
  background: rgba(34, 76, 90, 0.17);
}

.stat-label {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #071226;
  font-size: 28rpx;
  font-weight: 800;
  white-space: nowrap;
}

.stat-icon {
  width: 32rpx;
  height: 32rpx;
}

.stat-number-row {
  margin-top: 24rpx;
  display: flex;
  align-items: baseline;
}

.stat-number {
  color: #030508;
  font-size: 62rpx;
  line-height: 1;
  font-weight: 800;
}

.stat-unit {
  margin-left: 6rpx;
  color: #006968;
  font-size: 28rpx;
  font-weight: 800;
}

.stat-desc {
  margin-top: 22rpx;
  display: block;
  color: #657084;
  font-size: 26rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.quick-actions {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 96rpx;
  border-top: 2rpx solid rgba(0, 104, 103, 0.2);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.48);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  align-items: center;
}

.quick-action {
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #071226;
  font-size: 30rpx;
  font-weight: 900;
}

.quick-action-active {
  opacity: 0.66;
}

.quick-action:not(:last-child) {
  border-right: 2rpx solid rgba(34, 76, 90, 0.17);
}

.quick-icon {
  width: 42rpx;
  height: 42rpx;
}

.deal-feed {
  position: relative;
  z-index: 2;
  margin-top: 64rpx;
  height: auto;
  padding-bottom: 32rpx;
}

.deal-card {
  position: relative;
  min-height: 324rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid rgba(8, 23, 43, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.84);
  overflow: hidden;
}

.deal-head {
  padding: 0 4rpx 20rpx;
}

.more-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #667185;
  font-size: 26rpx;
}

.right-arrow {
  font-size: 42rpx;
  line-height: 1;
}

.deal-image {
  position: absolute;
  left: 28rpx;
  top: 28rpx;
  width: 228rpx;
  height: 268rpx;
  border-radius: 16rpx;
  background: #e7f4f3;
}

.deal-info {
  position: absolute;
  left: 286rpx;
  top: 28rpx;
  width: 362rpx;
  bottom: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.deal-title {
  display: block;
  color: #071226;
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
  max-width: 356rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.tag-row {
  margin-top: 12rpx;
  display: flex;
  gap: 16rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #f0f2f3;
  color: #596475;
  font-size: 24rpx;
  line-height: 1;
  white-space: nowrap;
}

.coupon-badge {
  margin-top: 12rpx;
  display: inline-flex;
  padding: 10rpx 14rpx;
  border-radius: 10rpx;
  background: #fff0eb;
  color: #ef4024;
  font-size: 28rpx;
  line-height: 1;
}

.price-row {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  width: 100%;
  flex-wrap: nowrap;
  white-space: nowrap;
}

.price {
  color: #ef4b2e;
  font-size: 40rpx;
  line-height: 1;
  font-weight: 800;
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.market-price {
  display: none;
}

.view-button {
  position: static;
  flex: none;
  width: 96rpx;
  height: 48rpx;
  min-height: 0;
  min-width: 96rpx;
  padding: 0 8rpx;
  border-radius: 28rpx;
  background: #00706f;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1;
}

.home-page,
.home-page view,
.home-page text {
  font-weight: 400;
}

.hero-title,
.stat-number,
.deal-head .card-title,
.deal-title,
.price {
  font-weight: 800 !important;
}
