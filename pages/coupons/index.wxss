page {
  background: #f8fcfc;
}

.coupon-tab-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 110rpx 32rpx 154rpx;
  background:
    radial-gradient(ellipse 420rpx 360rpx at 0% 0%, rgba(180, 236, 225, 0.58) 0, rgba(219, 246, 241, 0.34) 34%, rgba(255, 255, 255, 0) 68%),
    linear-gradient(180deg, #ecfbf8 0%, #f8fcfc 28%, #ffffff 78%, #f8fbfb 100%);
}

.topbar {
  height: 68rpx;
  display: grid;
  grid-template-columns: 116rpx 1fr 154rpx;
  gap: 34rpx;
  align-items: center;
}

.city {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #071226;
  font-size: 40rpx;
  line-height: 1;
}

.chevron {
  margin-top: -6rpx;
  font-size: 40rpx;
}

.search-box {
  height: 64rpx;
  padding: 0 26rpx;
  border: 2rpx solid rgba(8, 23, 43, 0.17);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.82);
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #747b86;
  font-size: 28rpx;
  white-space: nowrap;
}

.search-icon {
  font-size: 42rpx;
  line-height: 1;
  transform: rotate(-20deg);
}

.search-text {
  overflow: hidden;
  text-overflow: ellipsis;
}

.capsule-space {
  width: 154rpx;
  height: 64rpx;
}

.category-grid {
  margin-top: 42rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 0;
}

.category-item {
  min-width: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.category-icon {
  width: 72rpx;
  height: 72rpx;
}

.category-label {
  color: #071226;
  font-size: 24rpx;
  line-height: 1.2;
  white-space: nowrap;
}

.category-active {
  color: #006b68;
  font-weight: 800;
}

.filter-row {
  margin-top: 32rpx;
  display: flex;
  gap: 14rpx;
  overflow: hidden;
}

.filter-chip {
  height: 56rpx;
  padding: 0 28rpx;
  border: 1rpx solid #d4e8e8;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #4e5b6b;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.filter-active {
  color: #006b68;
  background: #eaf7f6;
  border-color: #bde0df;
  font-weight: 800;
}

.deal-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.deal-card {
  min-height: 210rpx;
  padding: 14rpx;
  border: 1rpx solid rgba(8, 23, 43, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.9);
  box-sizing: border-box;
  display: flex;
}

.deal-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #e7f4f3;
}

.deal-info {
  min-width: 0;
  flex: 1;
  margin-left: 16rpx;
  position: relative;
  padding-bottom: 38rpx;
}

.deal-title {
  max-width: 100%;
  color: #071226;
  font-size: 29rpx;
  line-height: 1.25;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.merchant-name {
  margin-top: 6rpx;
  color: #006b68;
  font-size: 23rpx;
  line-height: 1.2;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.meta-row,
.rating-row {
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
  color: #6b7584;
  font-size: 22rpx;
  line-height: 1.2;
}

.rating-row {
  position: relative;
  padding-right: 72rpx;
}

.distance {
  position: absolute;
  right: 0;
}

.deal-bottom {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.price-wrap {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
}

.price {
  color: #ef4b2e;
  font-size: 38rpx;
  line-height: 1;
  font-weight: 800;
}

.discount {
  color: #ef4b2e;
  font-size: 22rpx;
  line-height: 1.1;
}

.buy-btn {
  min-width: 128rpx;
  height: 48rpx;
  padding: 0 14rpx;
  border-radius: 24rpx;
  background: #00706f;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.coupon-badge {
  position: absolute;
  left: 0;
  bottom: 0;
  max-width: 210rpx;
  padding: 4rpx 10rpx;
  border: 1rpx solid rgba(239, 75, 46, 0.22);
  border-radius: 8rpx;
  color: #ef4b2e;
  background: #fff4f1;
  font-size: 21rpx;
  line-height: 1.1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
