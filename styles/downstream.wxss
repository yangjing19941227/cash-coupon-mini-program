.ds-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 110rpx 32rpx 54rpx;
  background:
    radial-gradient(ellipse 380rpx 520rpx at 0% 0%, rgba(184, 236, 225, 0.58) 0, rgba(219, 246, 241, 0.26) 36%, rgba(255, 255, 255, 0) 68%),
    linear-gradient(180deg, #f8fdfc 0%, #f7fbfa 44%, #ffffff 100%);
  color: #071426;
}

.ds-page.with-tab {
  padding-bottom: 150rpx;
}

.ds-top {
  position: relative;
  z-index: 2;
  height: 72rpx;
  display: grid;
  grid-template-columns: 120rpx 1fr 154rpx;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 28rpx;
}

.ds-top-main {
  grid-template-columns: auto 1fr 154rpx;
}

.ds-back {
  color: #071426;
  font-size: 58rpx;
  line-height: 1;
}

.ds-location {
  color: #071426;
  font-size: 28rpx;
  font-weight: 700;
  white-space: nowrap;
}

.ds-title {
  text-align: center;
  color: #071426;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1;
}

.ds-capsule {
  height: 64rpx;
  border: 1rpx solid rgba(8, 23, 43, 0.12);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.64);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22rpx;
  color: #000;
  font-size: 32rpx;
  font-weight: 900;
  visibility: hidden;
}

.ds-capsule-line {
  width: 1rpx;
  height: 34rpx;
  background: #d8dde2;
}

.ds-mini-circle {
  width: 34rpx;
  height: 34rpx;
  border: 6rpx solid #000;
  border-radius: 50%;
}

.ds-card {
  border: 1rpx solid rgba(8, 23, 43, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  box-sizing: border-box;
  overflow: hidden;
}

.ds-soft-card {
  border: 1rpx solid rgba(0, 104, 103, 0.18);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.64);
  box-sizing: border-box;
}

.ds-btn {
  min-height: 76rpx;
  padding: 0 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #007a75, #005f5d);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.ds-btn-block {
  width: 100%;
  height: 88rpx;
  border-radius: 20rpx;
}

.ds-outline-btn {
  min-height: 66rpx;
  padding: 0 28rpx;
  border: 2rpx solid #00706f;
  border-radius: 36rpx;
  color: #006b68;
  background: rgba(255, 255, 255, 0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.ds-tag {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 14rpx;
  border-radius: 8rpx;
  background: #f0f2f3;
  color: #596475;
  font-size: 22rpx;
  line-height: 1;
  white-space: nowrap;
}

.ds-tag-warn {
  background: #fff1d9;
  color: #c77a00;
}

.ds-teal {
  color: #006b68;
}

.ds-red {
  color: #ef4b2e;
}

.ds-muted {
  color: #667185;
}

.ds-section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.ds-section-title {
  color: #071426;
  font-size: 34rpx;
  font-weight: 900;
}

.ds-round-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #e9f4f2;
  color: #006b68;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
}

.ds-tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 156rpx;
  border-top: 1rpx solid rgba(8, 23, 43, 0.08);
  background: rgba(255, 255, 255, 0.95);
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  padding-top: 18rpx;
  z-index: 10;
  box-sizing: border-box;
}

.ds-tab {
  text-align: center;
  color: #6f7d8c;
  font-size: 24rpx;
  line-height: 1.2;
}

.ds-tab image {
  display: block;
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 6rpx;
}

.ds-tab-active {
  color: #006b68;
  font-weight: 800;
}

.ds-home-indicator {
  position: fixed;
  left: 252rpx;
  bottom: 10rpx;
  width: 246rpx;
  height: 10rpx;
  border-radius: 10rpx;
  background: #000;
  z-index: 11;
}

.ds-info-line {
  min-height: 84rpx;
  border-bottom: 1rpx solid rgba(8, 23, 43, 0.08);
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #667185;
  font-size: 26rpx;
}

.ds-info-line:last-child {
  border-bottom: 0;
}
